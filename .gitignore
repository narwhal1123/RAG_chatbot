# === OS generated files (운영체제 생성 파일) ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === IDEs and Editors (개발 도구 설정 파일) ===
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# === Package Manager & Dependencies (의존성 라이브러리 - 절대 올리면 안 됨) ===
node_modules/
jspm_packages/
.pnp/
.pnp.js
vendor/

# === Build outputs (빌드 결과물 및 배포 폴더) ===
dist/
build/
out/
bin/
obj/

# === Logs and runtimes (로그 및 임시 파일) ===
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pids
*.pid
*.seed
*.pid.lock

# === Env & Secrets (보안/환경 변수 파일 - 절대 올리면 안 됨) ===
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key